# Environment Configuration Template
# Copy this file to .env for team defaults
# Copy this file to .env.local for local machine-specific overrides
# NEVER commit .env.local to version control

# ==============================================================================
# ENVIRONMENT
# ==============================================================================
ENVIRONMENT=dev  # dev, test, prod

# ==============================================================================
# GPU CONFIGURATION (Auto-detected if not set)
# ==============================================================================
# GPU backend is auto-detected: CUDA (NVIDIA) > Metal (Apple Silicon) > CPU
# Uncomment to override (useful for forcing CPU in CI/CD or testing)
# GPU_BACKEND=cpu  # cuda, metal, or cpu
# GPU_DEVICE_NAME=  # Auto-detected if not set

# ==============================================================================
# LLM API KEYS (Cloud-first approach)
# ==============================================================================
# At least one provider should be configured for production
GROQ_API_KEY=your_groq_api_key_here
DEEPSEEK_API_KEY=your_deepseek_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GOOGLE_API_KEY=your_google_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# ==============================================================================
# EMBEDDINGS (Local via text-embeddings-inference)
# ==============================================================================
# text-embeddings-inference server URL (BGE-base-en-v1.5 model)
# For local development: http://localhost:8080
# For Docker Compose: http://text-embeddings:8080
EMBEDDINGS_URL=http://localhost:8080

# ==============================================================================
# VECTOR DATABASE (ChromaDB)
# ==============================================================================
# ChromaDB server URL
# For local development: http://localhost:8000
# For Docker Compose: http://chroma:8000
# For production: Use Qdrant cloud or Weaviate
CHROMA_URL=http://localhost:8000
CHROMA_API_KEY=  # Optional for local dev

# ==============================================================================
# REDIS (Cache + State)
# ==============================================================================
# Redis connection URL
# For local development: redis://localhost:6379
# For Docker Compose: redis://redis:6379
# For production: Use managed Redis (AWS ElastiCache, Redis Cloud, etc.)
REDIS_URL=redis://localhost:6379

# ==============================================================================
# POSTGRES (Optional - for complex agent state)
# ==============================================================================
# PostgreSQL connection URL (optional, used by application code)
# For local development: postgresql://agentic_ai:password@localhost:5432/agentic_ai
# For Docker Compose: postgresql://agentic_ai:password@postgres:5432/agentic_ai
POSTGRES_URL=

# Docker Compose Postgres credentials (required when using the optional profile)
# These are consumed by infra/docker-compose.yml via the ${VAR:?} pattern;
# `docker compose config` fails fast if any of them is empty so a default
# password can never silently boot.
POSTGRES_USER=agentic_ai
POSTGRES_PASSWORD=
POSTGRES_DB=agentic_ai

# ==============================================================================
# NEO4J (Optional - graph RAG demo, Article 1)
# ==============================================================================
# Docker Compose Neo4j credentials (required when using the optional profile)
# Format: user/password (single env var, slash-separated, per Neo4j convention).
# Consumed by infra/docker-compose.yml via the ${VAR:?} pattern.
NEO4J_AUTH=neo4j/

# ==============================================================================
# OBSERVABILITY (Arize Phoenix - local dev)
# ==============================================================================
# Phoenix server URL and OTLP trace collector endpoint
# For local development: http://localhost:6006
# For Docker Compose: http://phoenix:6006
# For production (Article 6+): Migrate to LangFuse
PHOENIX_URL=http://localhost:6006
PHOENIX_COLLECTOR_ENDPOINT=http://localhost:6006/v1/traces

# ==============================================================================
# LLM CONFIGURATION
# ==============================================================================
# Default LLM model for development (format: provider/model)
DEFAULT_LLM_MODEL=groq/llama-3-8b
DEFAULT_LLM_TEMPERATURE=0.7
DEFAULT_LLM_MAX_TOKENS=1000
LLM_REQUEST_TIMEOUT=30  # seconds

# ==============================================================================
# COST MANAGEMENT
# ==============================================================================
MONTHLY_BUDGET_USD=100
COST_ALERT_THRESHOLD=0.8  # Alert at 80% of budget

# ==============================================================================
# CACHE CONFIGURATION
# ==============================================================================
CACHE_TTL_SECONDS=86400  # 24 hours
SEMANTIC_CACHE_THRESHOLD=0.95  # Cosine similarity threshold

# ==============================================================================
# DEVELOPMENT
# ==============================================================================
DEBUG=false
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL
