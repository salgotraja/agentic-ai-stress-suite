# Environment Configuration Template
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control

# Environment
ENVIRONMENT=dev  # dev, test, prod

# LLM API Keys (cloud-first approach)
GROQ_API_KEY=your_groq_api_key_here
DEEPSEEK_API_KEY=your_deepseek_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GOOGLE_API_KEY=your_google_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Embeddings (local via text-embeddings-inference)
EMBEDDINGS_URL=http://localhost:8080

# Vector DB (Chroma - local dev)
CHROMA_URL=http://localhost:8000
CHROMA_API_KEY=dev-token

# Redis (cache + state)
REDIS_URL=redis://localhost:6379

# Postgres (optional)
POSTGRES_URL=postgresql://agentic_ai:change_me_in_production@localhost:5432/agentic_ai

# Observability (Phoenix - local dev)
PHOENIX_URL=http://localhost:6006
PHOENIX_COLLECTOR_ENDPOINT=http://localhost:6006/v1/traces

# LLM Configuration
DEFAULT_LLM_MODEL=groq/llama-3-8b
DEFAULT_LLM_TEMPERATURE=0.7
DEFAULT_LLM_MAX_TOKENS=1000
LLM_REQUEST_TIMEOUT=30

# Cost Management
MONTHLY_BUDGET_USD=100
COST_ALERT_THRESHOLD=0.8  # Alert at 80% of budget

# Cache Configuration
CACHE_TTL_SECONDS=86400  # 24 hours
SEMANTIC_CACHE_THRESHOLD=0.95  # Cosine similarity threshold

# Development
DEBUG=true
LOG_LEVEL=INFO
