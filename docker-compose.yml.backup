services:
  # Redis (cache + state persistence, from Phase 1)
  # Teaching note: Redis serves dual purpose in this architecture:
  # 1. L1 exact-match cache for LLM responses (Article 6)
  # 2. Distributed state backend for multi-agent systems (Article 5)
  #
  # Why Redis:
  # - Fast: In-memory, sub-millisecond latency
  # - Persistent: AOF (append-only file) for durability
  # - Simple: Key-value API, no schema management
  # - Mature: Battle-tested, 15+ years in production
  #
  # Configuration:
  # - appendonly yes: Persist writes to disk (durability)
  # - maxmemory 1gb: Prevent OOM on dev machines
  # - allkeys-lru: Evict least-recently-used keys when full
  redis:
    image: redis:7-alpine
    container_name: agentic-ai-redis
    restart: unless-stopped
    ports:
      - "6379:6379"
    command: redis-server --appendonly yes --maxmemory 1gb --maxmemory-policy allkeys-lru
    volumes:
      - redis-data:/data
    healthcheck:
      test: ["CMD", "redis-cli", "ping"]
      interval: 30s
      timeout: 10s
      retries: 3
    deploy:
      resources:
        limits:
          memory: 1G

  # Chroma (vector database, local dev)
  # Teaching note: Chroma is the baseline vector DB for development.
  # Articles 1-2 use Chroma, Article 8 migrates to Weaviate/Qdrant for production.
  #
  # Why Chroma for dev:
  # - Simple: SQLite-backed, no cluster management
  # - Fast setup: Single container, works immediately
  # - Good enough: Handles 10K-100K docs fine
  # - Python-native: Built for Python ML workflows
  #
  # Limitations (addressed in Article 8):
  # - No distributed mode (single node only)
  # - Limited filtering capabilities vs Weaviate
  # - No HNSW tuning exposed
  #
  # Configuration:
  # - Token auth enabled via chroma-auth.yaml
  # - Persist directory ensures data survives restarts
  chroma:
    image: chromadb/chroma:latest
    container_name: agentic-ai-chroma
    restart: unless-stopped
    ports:
      - "8000:8000"
    environment:
      - CHROMA_SERVER_AUTHN_CREDENTIALS_FILE=/chroma/auth.yaml
      - CHROMA_SERVER_AUTHN_PROVIDER=chromadb.auth.token_authn.TokenAuthenticationServerProvider
      - PERSIST_DIRECTORY=/chroma/data
    volumes:
      - chroma-data:/chroma/data
      - ./infra/chroma-auth.yaml:/chroma/auth.yaml:ro
    healthcheck:
      test: ["CMD", "/bin/bash", "-c", "cat < /dev/null > /dev/tcp/localhost/8000"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 20s
    deploy:
      resources:
        limits:
          memory: 2G

  # Phoenix (observability, local dev)
  # Teaching note: Phoenix provides local-first observability for LLM apps.
  # Used in Phase 1-5, migrated to LangFuse for production in Article 6.
  #
  # Why Phoenix for dev:
  # - Local-first: No cloud dependencies, works offline
  # - Simple setup: Single container, no config needed
  # - LLM-aware: Understands traces, spans, embeddings
  # - Visual: UI for exploring traces and debugging
  #
  # Features:
  # - Trace collection via OTLP (OpenTelemetry)
  # - Embedding visualization (UMAP projections)
  # - Latency/cost analysis per trace
  # - Session tracking for multi-turn conversations
  #
  # Port 6006: HTTP UI and OTLP collector
  phoenix:
    image: arizephoenix/phoenix:latest
    container_name: agentic-ai-phoenix
    restart: unless-stopped
    ports:
      - "6006:6006"
    environment:
      - PHOENIX_PORT=6006
      - PHOENIX_WORKING_DIR=/phoenix-data
    volumes:
      - phoenix-data:/phoenix-data
    healthcheck:
      test: ["CMD", "python", "-c", "import urllib.request; urllib.request.urlopen('http://127.0.0.1:6006/healthz', timeout=1)"]
      interval: 10s
      timeout: 5s
      retries: 3
      start_period: 10s
    deploy:
      resources:
        limits:
          memory: 1G

  # Postgres (optional, future requirement for complex agent state)
  # Teaching note: Postgres is OPTIONAL in Phase 1. Required for Article 5+.
  # To start Postgres: docker-compose --profile optional up postgres
  #
  # Use cases:
  # - Structured agent state (conversation history with metadata)
  # - Audit logs (tamper-evident, queryable)
  # - Eval result storage (RAGAS metrics over time)
  # - Multi-agent coordination (shared task queue)
  #
  # Why Postgres:
  # - ACID transactions (critical for agent state consistency)
  # - Rich query capabilities (JOIN, window functions)
  # - JSON support (flexible schema for agent state)
  # - pgvector extension (hybrid search in Article 8)
  postgres:
    image: postgres:16-alpine
    container_name: agentic-ai-postgres
    restart: unless-stopped
    ports:
      - "5432:5432"
    environment:
      - POSTGRES_USER=agentic_ai
      - POSTGRES_PASSWORD=change_me_in_production
      - POSTGRES_DB=agentic_ai
      - PGDATA=/var/lib/postgresql/data/pgdata
    volumes:
      - postgres-data:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U agentic_ai"]
      interval: 30s
      timeout: 10s
      retries: 3
    deploy:
      resources:
        limits:
          memory: 512M
    profiles:
      - optional

volumes:
  redis-data:
    driver: local
  chroma-data:
    driver: local
  phoenix-data:
    driver: local
  postgres-data:
    driver: local

networks:
  default:
    name: agentic-ai-network
